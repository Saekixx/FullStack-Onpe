<!DOCTYPE html>
<html>
<head>
    <title>ONPE - Oficina Nacional de Procesos Electorales</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=9" />
    <link href="~/css/bootstrap.css" rel="stylesheet" type="text/css" media="screen" />
    <link href="~/css/font-awesome.min.css" rel="stylesheet" type="text/css" media="screen" />
    <link href="~/css/style.css" rel="stylesheet" type="text/css" media="screen" />
</head>
    <body>
        <header>
            <div class="container">
                <div class="pull-left logo-onpe">
                    <div class="pull-left">
                    <a href=@Url.Action("Inicio", "Onpe")><img src="~/images/onpe-trans.png"></a>
                    </div>

                    <div class="pull-left">
                        <h1>PRESENTACIÓN DE RESULTADOS</h1>
                    </div>
                </div>

                <div class="pull-right logo">
                    <img src="~/images/eegg2016-trans.png" width="218" height="35">
                </div>
            </div>
        </header>

    <section class="container space02 nosub">
		@RenderBody()
    </section>

    <footer class="footer-index">
        <div class="container">
            <div class="row">
                <div class="col-md-12 direc01">
                    <span>CONTÁCTENOS</span>
                    <p>Jr. Washington 1894, Cercado de Lima </p>
                    <p>Correo electrónico: <a href="#">informes@onpe.gob.pe</a></p>
                    <p>Central Telefónica: 417 - 0630 / Lunes a Viernes 08:30 - 16:30 hrs</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://www.gstatic.com/charts/loader.js"></script>
    <script>
                function crearGraficoParticipacion(id, participacion, ausentismo) {
            google.charts.load('current', { packages: ['corechart'] });
            google.charts.setOnLoadCallback(drawChart);

            function drawChart() {
                var data = google.visualization.arrayToDataTable([
                    ['Tipo', 'Porcentaje'],
                    ['Participación', participacion],
                    ['Ausentismo', ausentismo]
                ]);

                var formatter = new google.visualization.NumberFormat({
                    pattern: '#,##0.000' 
                });
                formatter.format(data, 1); 

                var options = {
                    is3D: true,
                    slices: {
                        1: { offset: 0.2 }
                    },
                    colors: ['#2f4b7c', '#c0c0c0'],
                    pieSliceText: 'value',
                    tooltip: {
                        text: 'both',
                        trigger: 'focus'
                    },
                    legend: { position: 'right', textStyle: { fontSize: 12 } }
                };

                var chart = new google.visualization.PieChart(
                    document.getElementById(id)
                );

                chart.draw(data, options);
            }
        }
    </script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Entrega de datos desde C# a JS
            const dptosPeru = @Html.Raw(Json.Serialize(ViewBag.DepartamentosPeru));
            const dptosExt = @Html.Raw(Json.Serialize(ViewBag.DepartamentosExtranjero));

            $('#cdgoAmbito').change(function () {
                // Obtenemos el valor seleccionado ('P' o 'E')
                const ambito = $(this).val();
                const $comboDep = $('#cdgoDep');

                // 2. LIMPIEZA TOTAL: Borramos todo lo anterior
                $comboDep.find('option').remove();
                $comboDep.append('<option value="">--SELECCIONE--</option>');

                // 3. SELECCIÓN DE LISTA
                let listaAMostrar = [];
                if (ambito === "P") {
                    listaAMostrar = dptosPeru;
                    console.log("Cargando lista de Perú...");
                } else if (ambito === "E") {
                    listaAMostrar = dptosExt;
                    console.log("Cargando lista de Extranjero...");
                }

                // 4. LLENADO
                if (listaAMostrar && listaAMostrar.length > 0) {
                    listaAMostrar.forEach(item => {
                        // Usamos item.dpd (asegúrate que en C# sea DPD)
                        $comboDep.append(`<option value="${item.dpd}">${item.dpd}</option>`);
                    });
                } else {
                    console.error("La lista seleccionada está vacía o es nula");
                }
            });

            // Disparo inicial
            $('#cdgoAmbito').trigger('change');
        });
    </script>

    </body>
</html>